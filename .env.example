# Copy to `.env` — never commit `.env`.

# --- Supabase (required; safe to expose anon key — RLS protects data) ---
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Do not add SUPABASE_SERVICE_ROLE_KEY here for the Vite client — use only in trusted server code.

# --- Market data (dev / vite preview only — injected by vite-plugins/secureApiProxy.js, not bundled) ---
# Prefer these names over VITE_* so keys are not compiled into the browser bundle.
TWELVE_DATA_API_KEY=
COINGECKO_API_KEY=

# Legacy: the proxy also accepts VITE_TWELVE_DATA_API_KEY / VITE_COINGECKO_API_KEY if set.
