# --- Supabase (required for auth + portfolio data) ---
# Project Settings → API. Use the anon (public) key in the browser only.
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Never add SUPABASE_SERVICE_ROLE_KEY here for a Vite app — it would be exposed in the client bundle.

# --- Optional: market data (same as before) ---
VITE_TWELVE_DATA_API_KEY=
VITE_COINGECKO_API_KEY=
